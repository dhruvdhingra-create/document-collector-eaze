# ─── Database ───────────────────────────────────────────────────────────────
# Local PostgreSQL (Docker Compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eaze_docs"

# Supabase (replace with your project values)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Optional: only needed if you use Supabase-specific SDK features
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"

# Any other PostgreSQL (Neon, Railway, Fly, RDS, etc.)
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# SSL: set to "true" for cloud databases (Supabase, Neon, etc.)
DATABASE_SSL="false"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-secret-change-in-production"

# ─── File Storage ────────────────────────────────────────────────────────────
# Option A: MinIO (recommended for production — persistent, self-hosted)
# Set all three to enable MinIO; leave blank to fall back to local disk
S3_ENDPOINT=""        # e.g. minio.myserver.com (no http://, no trailing slash)
S3_PORT="9000"        # default MinIO port
S3_USE_SSL="false"    # set to "true" if MinIO is behind HTTPS
S3_ACCESS_KEY=""      # MinIO access key / username
S3_SECRET_KEY=""      # MinIO secret key / password
S3_BUCKET="documents" # bucket name (auto-created if it doesn't exist)

# Option B: Local disk fallback (dev only — files lost on container restart)
UPLOAD_DIR="./uploads"
